<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sorry Meri Zehru ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
overflow:hidden;
font-family:Poppins,sans-serif;
background:linear-gradient(-45deg,#ff5f8f,#ff8fb1,#ffc2d1,#ffdbe8);
background-size:400% 400%;
animation:bg 10s ease infinite;
}
@keyframes bg{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.card{
width:90%;
max-width:760px;
padding:40px;
border-radius:25px;
background:rgba(255,255,255,.18);
backdrop-filter:blur(15px);
text-align:center;
color:#fff;
box-shadow:0 0 40px rgba(0,0,0,.3);
}

h1{
font-family:"Great Vibes",cursive;
font-size:65px;
margin-bottom:15px;
text-shadow:0 0 15px white;
}

h2{
font-size:30px;
margin-bottom:20px;
}

#typing{
font-size:19px;
line-height:1.8;
min-height:170px;
}

.btn{
margin:15px;
padding:15px 35px;
border:none;
border-radius:50px;
font-size:18px;
font-weight:bold;
cursor:pointer;
transition:.3s;
}

.yes{
background:white;
color:#ff3b74;
}

.no{
background:#ff3b74;
color:white;
}

.btn:hover{
transform:scale(1.08);
}

.heart{
position:absolute;
color:white;
animation:float linear infinite;
opacity:.7;
}

@keyframes float{
0%{transform:translateY(100vh);}
100%{transform:translateY(-120px);}
}
</style>
</head>

<body>

<div class="card">

<h1>I'm Sorry 🥺❤️</h1>

<h2>Dear Zehru, Meri Pgli 💖</h2>

<p id="typing"></p>

<button class="btn yes" onclick="forgive()">Maaf Kiya ❤️</button>

<button class="btn no" onclick="think()">Thora Sochungi 🙈</button>

</div>

<script>

const text=`Meri Pyari Zehru ❤️

Mujhse jo bhi ghalti hui uske liye main dil se maafi mangta hoon.

Pgli... 🥺
Main nahi chahta ke tum meri wajah se udaas raho.

Tumhari smile mere liye bohot important hai.
Agar ho sake to apne is pagal dost ko ek aur chance de do.

Promise...
Main dobara tumhara dil dukhane ki koshish bhi nahi karunga. 🤍`;

let i=0;

function type(){
if(i<text.length){
document.getElementById("typing").innerHTML+=text.charAt(i);
i++;
setTimeout(type,40);
}
}

type();

function forgive(){
document.querySelector(".card").innerHTML=`
<h1>Thank You ❤️</h1>
<h2>I Love Your Smile 😊</h2>
<p style="font-size:22px">
Yayyy!! 🥹❤️<br><br>
Thank You Meri Pgli Zehru.<br>
Tumne maaf karke mera dil khush kar diya. 🌸💖
</p>`;
}

function think(){
alert("Main wait karunga... ❤️🥹");
}

for(let i=0;i<70;i++){
let h=document.createElement("div");
h.className="heart";
h.innerHTML="❤";
h.style.left=Math.random()*100+"vw";
h.style.fontSize=(15+Math.random()*25)+"px";
h.style.animationDuration=(4+Math.random()*5)+"s";
document.body.appendChild(h);
}

</script>

</body>
</html>